# A secret key used to encrypt user sessions (required, at least 32 characters)
# Generate a random secret key using: openssl rand -hex 32
SECRET_PASSWORD=

# The base url where this instance is accessible, including the scheme.
# Example: https://example.com
NEXT_PUBLIC_BASE_URL=https://web.local.rallly.co

# A connection string to your Postgres database.
# On Supabase, use the Transaction pooler connection string (port 6543).
DATABASE_URL=postgres://postgres:postgres@localhost:5450/rallly

# Direct (non-pooled) connection used only by Prisma migrations.
# On Supabase, set this to the Session pooler connection string (port 5432).
# DIRECT_DATABASE_URL=

# Maximum connections per pg pool instance.
# Set to a small value (e.g. 1) on serverless platforms such as Vercel.
# DATABASE_POOL_MAX=1

# Required to be able to send emails
SUPPORT_EMAIL=support@rallly.co

# SMTP settings for sending emails
# Defaults below are configured for the local Mailpit instance (see docker-compose.dev.yml)
SMTP_HOST=0.0.0.0
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PWD=

# Object Storage (S3) (optional)
# Defaults below are configured for the local Garage instance (see docker-compose.dev.yml)
# On Supabase, create a Storage bucket and S3 access keys, then set:
#   S3_BUCKET_NAME=<bucket name>
#   S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
#   S3_REGION=<project region, e.g. eu-west-2>
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY from Storage > S3 access keys
S3_BUCKET_NAME=rallly
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY_ID=rallly-access-key
S3_SECRET_ACCESS_KEY=rallly-secret-key
S3_REGION=garage
# Optional: serve stored assets directly from a CDN instead of proxying through /api/storage/
# NEXT_PUBLIC_CDN_BASE_URL=https://example.cloudfront.net

# KV (Redis) (optional)
# Defaults below are configured for the local Redis instance (see docker-compose.dev.yml)
# Leave both unset to use in-memory rate limiting and database-backed sessions.
KV_REST_API_URL=http://0.0.0.0:8079
KV_REST_API_TOKEN=dev_fake_token_123456789abcdefghijklmnop

# Toggle Self-Hosted mode
# Enable to remove the pay-wall and subscription billing functionality
NEXT_PUBLIC_SELF_HOSTED=false
